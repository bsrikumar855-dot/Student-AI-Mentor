# -----------------------------------------------------------------------------
# Drishta: Proactive AI Student Mentor Configuration
# Copy this file to '.env' and fill in your values.
# -----------------------------------------------------------------------------

# 1. LLM Configurations (OpenAI Compatible)
# Nvidia NIM API (Primary LLM)
NVIDIA_API_KEY="your-nvidia-api-key-here"
NVIDIA_LLM_MODEL="nvidia/llama-3.1-nemotron-70b-instruct"

# Groq API (Fallback LLM)
GROQ_API_KEY="your-groq-api-key-here"
GROQ_LLM_MODEL="llama-3.1-70b-versatile"

# 2. Database & Storage Config
# Path to SQLite database file. If left empty, backend falls back to :memory: DB.
POLARIS_PERSIST_PATH="store.db"

# 3. Security & Authentication
# API Key required to authenticate all client requests via X-API-Key header.
DRISHTA_API_KEY="drishta_secret_key"

# 4. CORS Allowed Origins (Comma-separated)
# Restricts which frontend domains can call the API.
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# 5. Development & Demo Flags
# Set to 'false' to fully disable the public /demo/* reset/test routes in production.
ALLOW_DEMO_ENDPOINTS="true"
