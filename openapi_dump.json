  "components": {
    "schemas": {
      "Body_ingest_cohort_api_v1_ingest_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_ingest_cohort_api_v1_ingest_post"
      },
      "ChatRequest": {
        "properties": {
          "student_id": {
            "type": "string",
            "title": "Student Id"
          },
          "message": {
            "type": "string",
            "maxLength": 2000,
            "title": "Message"
          },
          "history": {
            "items": {
              "$ref": "#/components/schemas/HistoryItem"
            },
            "type": "array",
            "maxItems": 50,
            "title": "History"
          }
        },
        "type": "object",
        "required": [
          "student_id",
          "message"
        ],
        "title": "ChatRequest"
      },
      "GradeRequest": {
        "properties": {
          "quality": {
            "type": "integer",
            "maximum": 5.0,
            "minimum": 0.0,
            "title": "Quality"
          }
        },
        "type": "object",
        "required": [
          "quality"
        ],
        "title": "GradeRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HistoryItem": {
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^(user|assistant|mentor)$",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "maxLength": 2000,
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "HistoryItem"
      },
      "ReviewRequest": {
        "properties": {
          "decision": {
            "type": "string",
            "pattern": "^(approve|override)$",
            "title": "Decision"
          },
          "note": {
            "anyOf": [
              {
